# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://clipflow:CHANGE_ME@localhost:5432/clipflow
POSTGRES_PASSWORD=CHANGE_ME  # generate: openssl rand -base64 32

# ── Redis (pin 7.4.x — AGPLv3 concern on v8+) ────────────────
REDIS_URL=redis://:CHANGE_ME@localhost:6379
REDIS_PASSWORD=CHANGE_ME     # generate: openssl rand -base64 32

# ── MinIO ────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME   # generate: openssl rand -hex 20
MINIO_SECRET_KEY=CHANGE_ME   # generate: openssl rand -base64 32
MINIO_BUCKET_SOURCES=clipflow-sources
MINIO_BUCKET_CLIPS=clipflow-clips
MINIO_BUCKET_SRT=clipflow-srt
MINIO_BUCKET_THUMBS=clipflow-thumbnails

# ── Encryption (CRITICAL — 32 bytes = 64 hex chars) ──────────
TOKEN_ENCRYPTION_KEY=CHANGE_ME   # openssl rand -hex 32
SESSION_COOKIE_SECRET=CHANGE_ME  # openssl rand -base64 24

# ── AI ───────────────────────────────────────────────────────
AI_PROVIDER=anthropic            # "anthropic" (default) or "openai"
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-CHANGE_ME      # required when AI_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini

# ── Auth ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# ── TikTok ───────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=CHANGE_ME
TIKTOK_CLIENT_SECRET=CHANGE_ME

# ── Instagram / Facebook ─────────────────────────────────────
META_APP_ID=CHANGE_ME
META_APP_SECRET=CHANGE_ME

# ── YouTube ──────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=CHANGE_ME
YOUTUBE_CLIENT_SECRET=CHANGE_ME

# ── X/Twitter ────────────────────────────────────────────────
TWITTER_CLIENT_ID=CHANGE_ME
TWITTER_CLIENT_SECRET=CHANGE_ME

# ── App ──────────────────────────────────────────────────────
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
PORT=3001
NODE_ENV=development

# ── GitHub (untuk MCP) ───────────────────────────────────────
GITHUB_TOKEN=ghp_CHANGE_ME
